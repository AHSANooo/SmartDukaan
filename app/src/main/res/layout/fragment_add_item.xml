<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgWhite">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/textPrimary"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="نیا آئٹم شامل کریں / Add New Item"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:gravity="center"/>

            <View
                android:layout_width="40dp"
                android:layout_height="40dp"/>
        </LinearLayout>

        <!-- Item Name Urdu -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="آئٹم کا نام (Item Name in Urdu) *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="8dp"/>

        <EditText
            android:id="@+id/etNameUrdu"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="مثال: چاول، چینی، تیل..."
            android:inputType="text"
            android:background="@drawable/edit_text_rounded"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Item Name English -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Item Name in English *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="8dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Rice, Sugar, Oil..."
            android:inputType="text"
            android:background="@drawable/edit_text_rounded"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Prices Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Buying Price -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="خریداری قیمت / Buying Price"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="8dp"/>

                <EditText
                    android:id="@+id/etBuying"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Rs 0"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edit_text_rounded"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="15sp"/>
            </LinearLayout>

            <!-- Selling Price -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="فروخت قیمت / Selling Price *"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="8dp"/>

                <EditText
                    android:id="@+id/etSelling"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Rs 0"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edit_text_rounded"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="15sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Quantity -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="مقدار / Quantity in Stock *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <EditText
            android:id="@+id/etQty"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="0"
            android:inputType="numberDecimal"
            android:background="@drawable/edit_text_rounded"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Category -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="قسم / Category"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/edit_text_rounded"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Barcode -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="بارکوڈ / Barcode (Optional)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etBarcode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="1234567890123"
                android:inputType="number"
                android:background="@drawable/edit_text_rounded"
                android:paddingStart="16dp"
                android:paddingEnd="56dp"
                android:textSize="15sp"/>

            <ImageButton
                android:id="@+id/btnScanBarcode"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_barcode"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Scan Barcode"/>
        </RelativeLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveItem"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/button_rounded"
            android:text="محفوظ کریں / Save Item"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="2dp"/>
    </LinearLayout>
</ScrollView>
