<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_navigation"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bgWhite"
    android:orientation="horizontal"
    android:elevation="8dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:baselineAligned="false">

    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        
        <ImageView
            android:id="@+id/nav_home_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_home"
            android:contentDescription="@string/nav_home"
            app:tint="@color/textSecondary"/>
        
        <TextView
            android:id="@+id/nav_home_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_home"
            android:textSize="11sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_sale"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        
        <ImageView
            android:id="@+id/nav_sale_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_sale"
            android:contentDescription="@string/nav_sale"
            app:tint="@color/textSecondary"/>
        
        <TextView
            android:id="@+id/nav_sale_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_sale"
            android:textSize="11sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_stock"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        
        <ImageView
            android:id="@+id/nav_stock_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_stock"
            android:contentDescription="@string/nav_stock"
            app:tint="@color/textSecondary"/>
        
        <TextView
            android:id="@+id/nav_stock_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_stock"
            android:textSize="11sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_reports"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        
        <ImageView
            android:id="@+id/nav_reports_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_reports"
            android:contentDescription="@string/nav_reports"
            app:tint="@color/textSecondary"/>
        
        <TextView
            android:id="@+id/nav_reports_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_reports"
            android:textSize="11sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        
        <ImageView
            android:id="@+id/nav_profile_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_profile"
            android:contentDescription="@string/nav_profile"
            app:tint="@color/textSecondary"/>
        
        <TextView
            android:id="@+id/nav_profile_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_profile"
            android:textSize="11sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
</LinearLayout>
